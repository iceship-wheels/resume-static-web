---
export interface Props {
  avatar?: string;
  bio: string;
  highlights?: string[];
}

const { avatar, bio, highlights = [] } = Astro.props;
---

<section id="about" class="py-24 px-6">
  <div class="max-w-5xl mx-auto">
    <h2 class="font-display text-3xl md:text-4xl font-bold mb-16 text-center">
      关于我
      <span class="block w-12 h-0.5 bg-accent mx-auto mt-4" />
    </h2>

    <div class="grid md:grid-cols-3 gap-12 items-start">
      {avatar && (
        <div class="md:col-span-1 flex justify-center">
          <div class="w-48 h-48 rounded-2xl overflow-hidden border-2 border-accent/30 shadow-lg shadow-accent/10">
            <img src={avatar} alt="头像" class="w-full h-full object-cover" />
          </div>
        </div>
      )}

      <div class={avatar ? 'md:col-span-2' : 'md:col-span-3'}>
        <p class="text-white/70 leading-loose text-lg font-light">
          {bio}
        </p>
        {highlights.length > 0 && (
          <div class="mt-8 grid grid-cols-2 md:grid-cols-3 gap-4">
            {highlights.map((h) => (
              <div class="bg-surface/50 rounded-xl px-4 py-3 text-center text-sm border border-white/5">
                <span class="text-accent font-medium">{h}</span>
              </div>
            ))}
          </div>
        )}
      </div>
    </div>
  </div>
</section>
