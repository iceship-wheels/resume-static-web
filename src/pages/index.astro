const skillGroups = [
  {
    name: '语言能力',
    items: ['大学英语六级 · 559分', '听说读写能力俱佳'],
  },
  {
    name: '办公与AI工具',
    items: ['Office · Keynote', 'Deepseek · 豆包 · 千问', '文档润色与创意文案生成'],
  },
  {
    name: '策展与设计',
    items: ['SketchUp 展厅建模', '展陈效果图生成', '展览活动策划'],
