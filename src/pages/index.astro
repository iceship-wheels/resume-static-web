  {
    role: '新媒体运营',
    company: '福建黄金时代传媒艺考中心',
    period: '2021.12 - 2022.02',
    description: '负责公众号"黄金时代EDU"的编写、运营工作，独立完成公众号推送30余篇，累计阅读量超1万次。',
    tags: ['内容策划', '公众号运营'],
