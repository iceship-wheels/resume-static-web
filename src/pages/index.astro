  {
    name: '新媒体与排版',
    items: ['秀米 · 可画', '公众号视觉化排版', '小红书 · 视频号 · IG · YouTube'],
  },
  {
    name: '影像创作',
    items: ['剪映后期制作', '活动摄影摄像', '风俗摄影', '图片后期修图'],
  },
];
---

<Layout title="骆影丽 | 策展人 · 视觉设计师 · 创意策划">
  <Hero
    name="骆影丽"
    title="策展人 / 新媒体运营 / 创意策划"
    subtitle="ART & CURATORIAL"
  />

  <!-- In-page section nav -->
  <nav class="sticky top-12 z-40 bg-primary/90 backdrop-blur-md border-b border-white/5">
    <div class="max-w-6xl mx-auto px-6 py-3 flex justify-center gap-6 md:gap-10 text-sm font-medium overflow-x-auto">
      <a href="#about" class="text-white/50 hover:text-accent transition-colors whitespace-nowrap">关于</a>
      <a href="#works" class="text-white/50 hover:text-accent transition-colors whitespace-nowrap">作品</a>
      <a href="#experience" class="text-white/50 hover:text-accent transition-colors whitespace-nowrap">经历</a>
      <a href="#skills" class="text-white/50 hover:text-accent transition-colors whitespace-nowrap">技能</a>
      <a href="#contact" class="text-white/50 hover:text-accent transition-colors whitespace-nowrap">联系</a>
    </div>
  </nav>

  <About
    avatar="/avatar.jpg"
    bio="北京电影学院电影理论与批评硕士在读，中国戏曲学院戏剧影视文学学士。拥有丰富的策展、新媒体运营及影视活动策划经验，曾参与策划多场国内外展览，主导国际学生影视作品展的志愿者管理与评委接待工作。擅长内容创作、视觉化排版与影像记录，英语六级559分，具备良好的跨文化交流能力。"
    highlights={['北电硕士在读', '北京市优秀毕业论文', '英语六级559分', '30+ 志愿者管理', '多平台运营经验', '国际策展经历']}
  />

  <Works works={works} />

  <Experience experiences={experiences} />

  <Skills groups={skillGroups} />

  <Contact
    email="riley18@163.com"
    phone="15280057010"
    wechat="15280057010"
    location="北京, 中国"
    socials={[
      { name: '小红书', url: '#' },
      { name: 'IG', url: '#' },
      { name: 'YouTube', url: '#' },
    ]}
  />
</Layout>
