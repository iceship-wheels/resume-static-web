  },
  {
    role: '映后交流场次摄影',
    company: '第14届北京国际电影节',
    period: '2024.04',
    description: '负责《逍遥游》《家庭简史》两个场次的映后交流场次现场摄影、图片整理和后期修图工作。',
    tags: ['摄影', '后期修图'],
  },
  {
    role: '场景设计助理、新媒体运营',
    company: '福建省厦门骆驼人片场',
    period: '2023.01 - 2023.02',
