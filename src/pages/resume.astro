---

<Layout title="骆影丽 求职简历">
  <style>
    @media print {
      nav, footer, .no-print { display: none !important; }
      body { background: white !important; color: black !important; }
      .print-white { background: white !important; color: black !important; }
      .print-gray { color: #374151 !important; }
      .print-dark { color: #111827 !important; }
      .print-red { color: #b91c1c !important; }
      .print-border-color { border-color: #e5e7eb !important; }
      @page { margin: 1.5cm 1.2cm 1.2cm 1.2cm; }
      section { break-inside: avoid; }
      h2 { break-after: avoid; }
    }
  </style>

  <div class="max-w-3xl mx-auto px-6 py-6 pb-20 print-white">

    <!-- Buttons -->
    <div class="no-print flex justify-center gap-4 mb-8">
      <button id="btn-paged"
        class="px-6 py-2 bg-accent text-white text-sm font-medium rounded-full hover:bg-accent/80 transition-colors inline-flex items-center gap-2"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
        导出 PDF (推荐)
      </button>
      <button
        onclick="window.print()"
        class="px-6 py-2 border border-white/20 text-white/60 text-sm font-medium rounded-full hover:border-accent hover:text-accent transition-colors inline-flex items-center gap-2"
      >
        浏览器打印
      </button>
    </div>

    <!-- Resume content for Paged.js -->
    <div id="resume-content">

    <!-- Header -->
    <div class="text-center mb-6 print-gray">
      <h1 class="font-display text-3xl font-bold tracking-wide print-dark">骆影丽</h1>
      <p class="text-white/50 print-gray text-xs mt-1">Riley Luo</p>
      <p class="text-white/60 print-gray text-xs mt-2">
        15280057010 &nbsp;|&nbsp; riley18@163.com &nbsp;|&nbsp; 2001.04 &nbsp;|&nbsp; MBTI: ISTJ
      </p>
    </div>

    <hr class="print-border-color border-white/10 mb-6" />

    <!-- Education -->
    <section class="mb-6">
      <h2 style="font-family: 'Playfair Display', serif; font-size: 1.125rem; font-weight: 700; color: #e94560; margin: 0 0 0.75rem 0;">教育背景</h2>
      <div class="space-y-4">
        {educations.map((edu) => (
          <div>
            <div class="flex flex-wrap items-baseline justify-between gap-2 mb-1">
              <h3 class="font-bold text-sm print-dark">{edu.school} · <span class="font-normal text-white/60 print-gray">{edu.major}</span></h3>
              <span class="text-xs text-accent font-medium whitespace-nowrap print-red">{edu.period}</span>
            </div>
            <ul class="space-y-1">
              {edu.details.map((d) => (
                <li class="text-xs text-white/70 print-gray ml-4 list-disc list-outside">{d}</li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </section>

    <!-- Internship -->
    <section class="mb-6">
      <h2 style="font-family: 'Playfair Display', serif; font-size: 1.125rem; font-weight: 700; color: #e94560; margin: 0 0 0.75rem 0;">实习经历</h2>
      <div class="space-y-4">
        {internships.map((exp) => (
          <div>
            <div class="flex flex-wrap items-baseline justify-between gap-2 mb-1">
              <h3 class="font-bold text-sm print-dark">{exp.company} · <span class="font-normal text-white/60 print-gray">{exp.role}</span></h3>
              <span class="text-xs text-accent font-medium whitespace-nowrap print-red">{exp.period}</span>
            </div>
            <ul class="space-y-0.5">
              {exp.points.map((p) => (
                <li class="text-xs text-white/70 print-gray ml-4 list-disc list-outside">{p}</li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </section>

    <!-- Campus -->
    <section style="margin-bottom: 1.5rem">
      <h2 style="font-family: 'Playfair Display', serif; font-size: 1.125rem; font-weight: 700; color: #e94560; margin: 0 0 0.75rem 0;">校园经历</h2>
      <div class="space-y-2">
        {campusExperiences.map((exp) => (
          <div class="flex flex-wrap items-baseline justify-between gap-2">
            <div>
              <span class="font-medium text-sm print-dark">{exp.org}</span>
              <span class="text-white/50 print-gray text-sm ml-2">{exp.role}</span>
            </div>
            <span class="text-xs text-accent font-medium whitespace-nowrap print-red">{exp.period}</span>
          </div>
        ))}
      </div>
    </section>

    <!-- Skills -->
    <section class="mb-6">
      <h2 style="font-family: 'Playfair Display', serif; font-size: 1.125rem; font-weight: 700; color: #e94560; margin: 0 0 0.75rem 0;">个人技能</h2>
      <ul class="space-y-1">
        {skills.map((s) => (
          <li class="text-xs text-white/70 print-gray ml-4 list-disc list-outside">{s}</li>
        ))}
      </ul>
    </section>

    </div>
    <!-- End resume-content -->

    <!-- Back link -->
    <div class="no-print text-center pt-4 pb-8">
      <a href={`${import.meta.env.BASE_URL}/`} class="text-sm text-white/40 hover:text-accent transition-colors">
        返回主页
      </a>
    </div>

  </div>
</Layout>

<script>
  import { Previewer } from 'pagedjs';

  document.getElementById('btn-paged').addEventListener('click', async () => {
    const btn = document.getElementById('btn-paged');
    btn.disabled = true;
    btn.textContent = '正在生成 PDF...';

    const content = document.getElementById('resume-content');
    const paged = new Previewer();

    try {
      const flow = await paged.preview(content, undefined, document.body);
      await flow.print();
    } catch (err) {
      console.error('Paged.js error:', err);
      alert('生成 PDF 失败，请尝试"浏览器打印"按钮。');
    } finally {
      btn.disabled = false;
      btn.textContent = '导出 PDF';
      // Clean up Paged.js rendered pages
      const pages = document.querySelectorAll('.pagedjs_page');
      pages.forEach(p => p.remove());
    }
  });
</script>
